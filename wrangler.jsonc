{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "isekai-website",
  "main": "./workers/isekai-docs.js",
  "compatibility_date": "2026-07-17",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "get.radcolor.dev/isekai*",
      "zone_name": "radcolor.dev"
    }
  ],
  "assets": {
    "directory": "./docs",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
